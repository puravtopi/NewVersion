@model PainTrax.Web.Models.PatientDetails

@{
    Layout = "~/Views/Shared/_IntakeLayout.cshtml";  // Use the admin layout
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .signature-pad {
        border: 1px solid #ccc;
        width: 100%;
        height: 150px;
        cursor: crosshair;
    }

    .section-title {
        font-weight: 600;
        margin-top: 25px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 5px;
    }

    .form-bottom-border {
        border: none;
        border-bottom: 2px solid #000;
        border-radius: 0;
        background: transparent;
        padding-left: 0;
    }

        .form-bottom-border:focus {
            box-shadow: none;
            border-bottom: 2px solid #000;
        }
</style>

<main id="main" class="main" style="margin-left:0px!important">

    <!-- End Page Title -->
    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">

                    <div class="card-body">
                        <div id="successMessage" class="alert alert-success" style="display:none">
                            <div class="container my-4">

                                <div class="text-center mb-4">
                                    Your signature has been successfully submitted.
                                    <br />
                                    The authorization form has been recorded in our system.
                                </div>
                            </div>
                        </div>
                        <div id="failMessage" class="alert alert-danger" style="display:none">
                            <div class="container my-4">

                                <div class="text-center mb-4">
                                    Unable to submit the form at the moment.
                                    <br />
                                    Please try again or contact the office if the issue continues.
                                </div>
                            </div>
                        </div>

                        <div class="container my-4" id="formDiv">

                            @if (Model.isExist)
                            {
                                <div id="successMessage" class="alert alert-success">
                                    <div class="container my-4">

                                        <div class="text-center mb-4">
                                            This authorization form was previously signed and recorded in our system. No additional signature is required.
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center mb-4">
                                    <h4 class="mb-0">Queens Medical Professional P.C.</h4>
                                    <p class="mb-0">115-24A Myrtle Avenue, Richmond Hill, New York 11418</p>
                                    <p>Ph: 718-480-6063 | Fax: 718-480-6093</p>

                                    <h5 class="mt-3"><b>PATIENT MASTER AUTHORIZATION & ACKNOWLEDGMENT</b></h5>
                                </div>

                                <form id="authorizationForm">
                                    <input type="hidden" value="@Model.id" id="id" name="id" />
                                    
                                    <div class="row g-3">

                                        <div class="col-md-4">
                                            <label class="form-label">Practice Name</label>
                                            <input type="text" class="form-control form-bottom-border" readonly="readonly" value="Queens Medical Professional PC">
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Patient Name</label>
                                            <input type="text" class="form-control form-bottom-border" readonly="readonly" name="patientName" value="@(Model.lname+ ' '+ Model.fname)">
                                        </div>

                                        <div class="col-md-2">
                                            <label class="form-label">Date of Birth</label>
                                            <input type="text" class="form-control form-bottom-border" readonly="readonly" name="dob" value="@(Model.dob==null?"": Model.dob.ToShortDateString())">
                                        </div>

                                        <div class="col-md-2">
                                            <label class="form-label">Date of Execution</label>
                                            <input type="text" class="form-control form-bottom-border" name="executionDate">
                                        </div>

                                    </div>


                                    <div class="section-title">PURPOSE OF THIS PAGE</div>

                                    <p>
                                        This page confirms my knowing and voluntary authorization for the documents listed below.
                                        I understand that instead of signing each document separately, my single signature on this
                                        page authorizes Queens Medical Professional PC (“the Practice”) to apply my signature and
                                        identifying information to the documents specifically listed here.
                                    </p>


                                    <div class="section-title">DOCUMENTS AUTHORIZED BY THIS SIGNATURE</div>

                                    <p>By signing below, I acknowledge and authorize the following documents:</p>

                                    <ul>
                                        <li>Assignment of Benefits (NF-15)</li>
                                        <li>HIPAA Authorization for Release of Medical Information</li>
                                        <li>Financial Responsibility / Non-Guarantee of Payment Agreement</li>
                                        <li>Consent for Examination, Evaluation, and Treatment</li>
                                        <li>Billing, Records, and Insurance Disclosure Authorization</li>
                                        <li>Workers’ Compensation Medical Information Authorization (if applicable)</li>
                                    </ul>

                                    <p>
                                        I understand that each document listed above has been explained to me,
                                        and I have the right to request and review a copy of each document.
                                    </p>


                                    <div class="section-title">AUTHORIZATION TO APPLY SIGNATURE</div>

                                    <ul>
                                        <li>Apply this signature together with my name and identifying information to each of the documents listed above</li>
                                        <li>Maintain each document as part of my medical and billing records</li>
                                        <li>Use this authorization for lawful medical, billing, and administrative purposes related to my care</li>
                                    </ul>

                                    <p>
                                        I understand that this signature has the same legal force and effect
                                        as if I had signed each document individually.
                                    </p>


                                    <div class="section-title">IMPORTANT ACKNOWLEDGMENTS</div>

                                    <ul>
                                        <li>No guarantees have been made regarding insurance coverage or payment</li>
                                        <li>Assignment of benefits does not guarantee payment</li>
                                        <li>I remain responsible for complying with No-Fault and Workers’ Compensation requirements</li>
                                        <li>This authorization does not apply to documents that legally require a separate claimant signature (such as an NF-2 application)</li>
                                    </ul>


                                    <div class="section-title">VOLUNTARY AND INFORMED CONSENT</div>

                                    <ul>
                                        <li>I have read and understand this page</li>
                                        <li>I had the opportunity to ask questions</li>
                                        <li>This document was explained to me in English</li>
                                        <li>I am signing voluntarily and without pressure</li>
                                    </ul>


                                    <div class="row mt-4">

                                        <div class="col-md-6">
                                            <label class="form-label"><b>Patient Signature</b></label>
                                            <br />
                                            <canvas id="signature-pad" style="border: 1px solid #000; cursor: crosshair;" crossorigin="anonymous"></canvas>

                                            <div class="mt-3" id="signaction">
                                                <button type="button" class="btn btn-danger" id="clear-signature">Clear</button>
                                                <button type="button" class="btn btn-warning" id="undo-signature">Undo</button>
                                                <button type="button" class="btn btn-secondary" id="redo-signature">Redo</button>

                                            </div>
                                        </div>


                                        <div class="col-md-6">

                                            @*  <label class="form-label">Practice Representative (Witness)</label>

                                        <div class="mb-3">
                                        <label>Name</label>
                                        <input type="text" class="form-control" name="witnessName">
                                        </div>

                                        <div class="mb-3">
                                        <label>Date</label>
                                        <input type="date" class="form-control" name="witnessDate">
                                        </div> *@

                                        </div>

                                    </div>


                                    <div class="text-center mt-4">
                                        <button class="btn btn-primary px-4" id="save-signature" type="button">Submit</button>
                                    </div>

                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
<script>

    const canvas = document.getElementById("signature-pad");
    const ctx = canvas.getContext("2d");

    let drawing = false;

    canvas.addEventListener("mousedown", () => drawing = true);
    canvas.addEventListener("mouseup", () => drawing = false);
    canvas.addEventListener("mousemove", draw);

    function draw(e) {
        if (!drawing) return;

        ctx.lineWidth = 2;
        ctx.lineCap = "round";

        const rect = canvas.getBoundingClientRect();

        ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
    }

    var signaturePad = new SignaturePad(canvas, {
        penColor: 'black',
        backgroundColor: 'white',
    });
    $(document).ready(function () {

        var undoStack = [];

        $("#clear-signature").click(function () {
            signaturePad.clear();
            undoStack = [];
        });

        $("#undo-signature").click(function () {
            var data = signaturePad.toData();
            if (data.length > 0) {
                var removedStroke = data.pop();
                undoStack.push(removedStroke);
                signaturePad.fromData(data);
            }
        });

        $("#redo-signature").click(function () {
            if (undoStack.length > 0) {
                var redoStroke = undoStack.pop();
                var data = signaturePad.toData();
                data.push(redoStroke);
                signaturePad.fromData(data);
            }
        });

        $("#save-signature").click(function () {
            if (signaturePad.isEmpty()) {
                alert("Please draw your signature before saving.");
            } else {
                var signatureData = signaturePad.toDataURL("image/jpeg");
                fnSaveSign(signatureData);
            }
        });

        function fnSaveSign(signatureData) {


            var url = '@Url.Action("SaveSign", "SendForm")';

            var id = $("#id").val();
           
            var data = {
                id: id,
                signatureData: signatureData,
            };

            $.ajax({
                type: "POST",
                url: url,
                data: JSON.stringify(data),
                contentType: "application/json",
                success: function (response) {
                    if (parseInt(response.id) > 0) {
                        $('#formDiv').hide();
                        $('#successMessage').show();
                    } else {
                        $('#formDiv').hide();
                        $('#failMessage').show();
                    }

                },
                error: function (xhr, status, error) {
                    console.log("Error saving signature:", xhr.status, error);
                },
            });
        }
    });

</script>
